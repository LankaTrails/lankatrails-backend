# Docker Compose Environment Variables - PRODUCTION TEMPLATE
# Copy this file to .env.prod and set secure values for production
# This file contains environment variables for Docker Compose services in production

# ==============================================
# APPLICATION SERVICE CONFIGURATION
# ==============================================
API_CONTAINER_NAME=your-api-container
API_IMAGE=your-org/your-api:latest
API_PORT=80
SPRING_PROFILES_ACTIVE=prod

# Application Configuration
APP_NAME=your-app-name
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=https://your-admin-domain.com,https://your-provider-domain.com,https://your-main-domain.com

# ==============================================
# DATABASE SERVICE CONFIGURATION
# ==============================================
POSTGRES_IMAGE=postgis/postgis:15-3.3-alpine
POSTGRES_CONTAINER_NAME=your-postgres-container
# POSTGRES_PORT not exposed in production

# Docker-specific database configuration (for containers)
DOCKER_DB_HOST=your-postgres-container
DOCKER_DB_PORT=5432
DOCKER_DB_NAME=your-database-name
DOCKER_DB_USERNAME=your-db-username
DOCKER_DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ==============================================
# REDIS SERVICE CONFIGURATION
# ==============================================
REDIS_IMAGE=redis:7-alpine
REDIS_CONTAINER_NAME=your-redis-container
# REDIS_PORT not exposed in production

# Docker-specific Redis configuration (for containers)
DOCKER_REDIS_HOST=your-redis-container
DOCKER_REDIS_PORT=6379
DOCKER_REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Redis application configuration
REDIS_SSL_ENABLED=false
REDIS_CACHE_KEY_PREFIX=your-app-prefix:
REDIS_CACHE_TTL=3600
CACHE_TYPE=redis

# ==============================================
# MONGODB SERVICE CONFIGURATION
# ==============================================
MONGODB_IMAGE=mongo:6-jammy
MONGODB_CONTAINER_NAME=your-mongodb-container
# MONGODB_PORT not exposed in production
MONGODB_DATABASE=your-database-name

# Docker-specific MongoDB configuration (for containers)
DOCKER_MONGODB_URI=mongodb://your-mongodb-container:27017/your-database-name

# ==============================================
# RABBITMQ SERVICE CONFIGURATION
# ==============================================
RABBITMQ_IMAGE=rabbitmq:3.12-management-alpine
RABBITMQ_CONTAINER_NAME=your-rabbitmq-container
RABBITMQ_AMQP_PORT=5672
# RABBITMQ_MANAGEMENT_PORT not exposed in production
RABBITMQ_STOMP_EXTERNAL_PORT=61613

# Docker-specific RabbitMQ configuration (for containers)
DOCKER_RABBITMQ_HOST=your-rabbitmq-container
DOCKER_RABBITMQ_PORT=5672
DOCKER_RABBITMQ_USERNAME=your-rabbitmq-username
DOCKER_RABBITMQ_PASSWORD=CHANGE_ME_IN_PRODUCTION

# RabbitMQ application configuration
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_STOMP_PORT=61613
RABBITMQ_ACK_MODE=auto
RABBITMQ_PREFETCH=10

# ==============================================
# JWT CONFIGURATION
# ==============================================
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_LONG_SECURE_KEY
JWT_EXPIRATION_MS=3600000
EMAIL_VERIFICATION_TOKEN_EXPIRATION_MS=900000
JWT_COOKIE_NAME=your_app_jwt
REFRESH_TOKEN_COOKIE_NAME=your_app_refresh_token

# ==============================================
# LOGGING CONFIGURATION (Production defaults)
# ==============================================
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_HIBERNATE_SQL=WARN
LOG_LEVEL_HIBERNATE_BINDER=WARN
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_LANKATRAILS=INFO

# ==============================================
# DEVELOPMENT FEATURES (Disabled for production)
# ==============================================
DEVTOOLS_RESTART_ENABLED=false
DEVTOOLS_LIVERELOAD_ENABLED=false
HIBERNATE_SHOW_SQL=false
HIBERNATE_USE_SQL_COMMENTS=false

# ==============================================
# MANAGEMENT/ACTUATOR CONFIGURATION (Secure defaults)
# ==============================================
MANAGEMENT_ENDPOINTS_EXPOSURE=health,info,metrics
MANAGEMENT_HEALTH_SHOW_DETAILS=when-authorized
MANAGEMENT_ENV_ENABLED=false
MANAGEMENT_BEANS_ENABLED=false
MANAGEMENT_BASE_PATH=/actuator
MANAGEMENT_SECURITY_ENABLED=true

# ==============================================
# FILE UPLOAD CONFIGURATION
# ==============================================
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB
# File upload root path - defaults to /app/uploads in Docker containers
# For production, this should be a persistent volume mount
FILE_UPLOAD_ROOT_PATH=/app/uploads

# ==============================================
# EMAIL CONFIGURATION
# ==============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME_IN_PRODUCTION
MAIL_PASSWORD=CHANGE_ME_IN_PRODUCTION
MAIL_FROM=CHANGE_ME_IN_PRODUCTION
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# ==============================================
# WEBSOCKET CONFIGURATION
# ==============================================
WEBSOCKET_MESSAGE_SIZE_LIMIT=2MB
WEBSOCKET_BUFFER_SIZE_LIMIT=4MB

# ==============================================
# STRIPE CONFIGURATION
# ==============================================
STRIPE_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
STRIPE_WEBHOOK_SECRET=CHANGE_ME_IN_PRODUCTION

# ==============================================
# GOOGLE OAUTH CONFIGURATION
# ==============================================
GOOGLE_MAPS_API_KEY=CHANGE_ME_IN_PRODUCTION

# ==============================================
# HEALTHCHECK CONFIGURATION
# ==============================================
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=5
HEALTHCHECK_START_PERIOD=120s